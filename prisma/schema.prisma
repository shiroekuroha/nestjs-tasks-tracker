generator client {
    provider   = "prisma-client-js"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
}

model Member {
    id             Int             @id @default(autoincrement())
    username       String          @db.VarChar(50)
    password       String          @db.VarChar(50)
    active         Boolean         @default(true)
    firstName      String          @db.VarChar(25)
    lastName       String          @db.VarChar(25)
    birthdate      DateTime        @db.Date
    email          String          @db.VarChar(50)
    phone          String?         @db.VarChar(18)
    address        String?         @db.VarChar(100)
    projectMembers ProjectMember[]
    taskMembers    TaskMember[]
    projects       Project[]
}

model Project {
    id            Int             @id @default(autoincrement())
    name          String          @db.VarChar(50)
    ownerId       Int
    member        Member          @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Project_Owner_fk")
    projectMember ProjectMember[]
    taskGroup     TaskGroup[]
}

model TaskGroup {
    id        Int     @id @default(autoincrement())
    name      String  @db.VarChar(50)
    color     String  @db.VarChar(9)
    position  Int
    projectId Int
    task      Task[]
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "TaskGroup_Project_fk")

    @@unique([projectId, position])
    @@unique([projectId, name])
}

model Task {
    id          Int          @id @default(autoincrement())
    name        String       @db.VarChar(50)
    description String
    position    Int
    status      StatusType
    startDate   DateTime?    @db.Timestamp(6)
    dueDate     DateTime?    @db.Timestamp(6)
    createdAt   DateTime     @default(now()) @db.Timestamp(6)
    updatedAt   DateTime     @default(now()) @updatedAt @db.Timestamp(6)
    taskGroupId Int
    attachment  Attachment[]
    checklist   Checklist[]
    taskGroup   TaskGroup    @relation(fields: [taskGroupId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Task_TaskGroup_fk")
    taskMember  TaskMember[]

    @@unique([taskGroupId, name])
    @@unique([taskGroupId, position])
}

model Attachment {
    id     Int    @id @default(autoincrement())
    name   String @db.VarChar(50)
    data   Bytes
    taskId Int
    task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Attachment_Task_fk")
}

model Checklist {
    id          Int     @id @default(autoincrement())
    name        String  @db.VarChar(50)
    description String
    completed   Boolean
    taskId      Int
    task        Task    @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Checklist_Task_fk")
}

model TaskMember {
    taskId   Int
    memberId Int
    member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)
    task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)

    @@id([taskId, memberId])
}

model ProjectMember {
    projectId Int
    memberId  Int
    roleId    Int?
    member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
    role      Role?   @relation(fields: [roleId], references: [id], onUpdate: NoAction)

    @@id([projectId, memberId])
}

model Role {
    id             Int              @id @default(autoincrement())
    name           String           @unique @db.VarChar(50)
    projectMember  ProjectMember[]
    rolePermission RolePermission[]
}

model Permission {
    id             Int              @id @default(autoincrement())
    name           String           @unique @db.VarChar(50)
    rolePermission RolePermission[]
}

model RolePermission {
    roleId       Int
    permissionId Int
    permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
    role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

    @@id([roleId, permissionId])
}

enum StatusType {
    TODO
    DOING
    DONE
}
